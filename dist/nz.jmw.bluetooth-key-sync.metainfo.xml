  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <name>Bluetooth Key Sync</name>
  <summary>Sync Bluetooth pairing keys between Windows and Linux</summary>

  <description>
    <p>
      Bluetooth Key Sync helps dual-boot users avoid re-pairing Bluetooth devices
      every time they switch between Windows and Linux. It reads pairing keys from
      a Windows SYSTEM registry hive, lets you visually match devices, and writes
      the synced keys to your Linux Bluetooth configuration.
    </p>
    <p>Features:</p>
    <ul>
      <li>Parse Windows SYSTEM registry hive files for Bluetooth pairing keys</li>
      <li>Scan Linux /var/lib/bluetooth/ configuration</li>
      <li>Visual device matching on an interactive node canvas</li>
      <li>Write synced keys to Linux Bluetooth config</li>
    </ul>
  </description>

  <categories>
    <category>Utility</category>
    <category>Settings</category>
    <category>System</category>
  </categories>

  <keywords>
    <keyword>bluetooth</keyword>
    <keyword>dual-boot</keyword>
    <keyword>pairing</keyword>
    <keyword>sync</keyword>
    <keyword>windows</keyword>
    <keyword>linux</keyword>
  </keywords>

